{% endcomment %}

{% stylesheet %}
  /* Submit Button Styles */
  .--pl--submit-button {
    background-color: var(--bg-color);
    transition:
      background-color 0.25s ease,
      color 0.25s ease,
      border-top 0.25s ease,
      border-bottom 0.25s ease,
      border-left 0.25s ease,
      border-right 0.25s ease;

    height: auto;
    width: var(--width, auto);
    max-width: var(--max-width, none);

    border-top: var(--border-top, none);
    border-bottom: var(--border-bottom, none);
    border-left: var(--border-left, none);
    border-right: var(--border-right, none);
    border-radius: var(--border-radius, 0);

    padding: var(--pl-padding-top) var(--pl-padding-right) var(--pl-padding-bottom)
      var(--pl-padding-left);

    font-family: var(--font-family);
    font-size: var(--font-size);
    font-weight: var(--font-weight);
    font-style: var(--font-style);
    color: var(--color);
    text-align: var(--text-alignment);
    line-height: normal;

    cursor: pointer;
    outline: none;
  }

  .--pl--submit-button-full-width {
    width: 100%;
    max-width: none;
  }

  .--pl--submit-button:hover {
    background-color: var(--bg-color-hover);
    color: var(--color-hover);
    border-top: var(--border-top-hover, var(--border-top));
    border-bottom: var(--border-bottom-hover, var(--border-bottom));
    border-left: var(--border-left-hover, var(--border-left));
    border-right: var(--border-right-hover, var(--border-right));
  }

  .--pl--submit-button:focus-visible {
    outline: 2px solid var(--border-color);
    outline-offset: 2px;
  }

  @media screen and (max-width: 768px) {
    .--pl--submit-button {
      width: var(--width-mobile, var(--width, auto));
      max-width: var(--max-width-mobile, var(--max-width, none));
      padding: var(--pl-padding-top-mobile) var(--pl-padding-right-mobile)
        var(--pl-padding-bottom-mobile) var(--pl-padding-left-mobile);
    }

    .--pl--submit-button-full-width {
      width: 100%;
      max-width: none;
    }
  }
{% endstylesheet %}

{% liquid
  assign bg_color = block.settings.background_color
  assign bg_color_hover = block.settings.background_color_hover
  assign custom_font = block.settings.font
  assign font_size = block.settings.font_size | abs | append: 'px'
  assign color = block.settings.color
  assign color_hover = block.settings.color_hover
  assign text_alignment = block.settings.text_alignment
  assign border_mode = block.settings.border_mode
%}

{% unless custom_font.system? %}
  <style>
    {{ custom_font | font_face: font_display: 'swap' }}
  </style>
{% endunless %}

{% comment %} Only construct border_value if border_mode is not 'none' {% endcomment %}
{% if border_mode != 'none' %}
  {% liquid
    assign border_value = block.settings.border_width | append: block.settings.border_width_unit | append: ' ' | append: block.settings.border_style | append: ' ' | append: block.settings.border_color
  %}
{% endif %}

<button
  type="submit"
  class="{% if block.settings.button_variant.css_class %}--pl--button {{ block.settings.button_variant.css_class }}{% else %}--pl--submit-button{% endif %} {% if block.settings.full_width == "true" %}--pl--submit-button-full-width{% endif %}"
  {{ block.shopify_attributes }}
  style="
    --bg-color: {{ bg_color }};
    --bg-color-hover: {{ bg_color_hover }};
    --color: {{ color }};
    --color-hover: {{ color_hover }};
    --border-color: {{ block.settings.border_color }};
    --border-color-hover: {{ block.settings.border_color_hover }};
    --border-radius: {{ block.settings.border_radius | append: 'px' }};
    --font-family: {{ custom_font.family | remove: '"' }};
    --font-size: {{ font_size }};
    --font-weight: {{ custom_font.weight }};
    --font-style: {{ custom_font.style }};
    --text-alignment: {{ text_alignment }};
    --width: {% if block.settings.full_width == "true" %}100%{% else %}auto{% endif %};
    --max-width: {% if block.settings.full_width == "true" %}none{% else %}auto{% endif %};
    --width-mobile: {% if block.settings.full_width_mob == "true" %}100%{% else %}auto{% endif %};
    --max-width-mobile: {% if block.settings.full_width_mob == "true" %}none{% else %}auto{% endif %};
    {% if border_mode == 'all' %}
      --border-top: {{ border_value }};
      --border-bottom: {{ border_value }};
      --border-left: {{ border_value }};
      --border-right: {{ border_value }};
      --border-top-hover: {{ block.settings.border_width }}{{ block.settings.border_width_unit | default: 'px' }} {{ block.settings.border_style }} {{ block.settings.border_color_hover }};
      --border-bottom-hover: {{ block.settings.border_width }}{{ block.settings.border_width_unit | default: 'px' }} {{ block.settings.border_style }} {{ block.settings.border_color_hover }};
      --border-left-hover: {{ block.settings.border_width }}{{ block.settings.border_width_unit | default: 'px' }} {{ block.settings.border_style }} {{ block.settings.border_color_hover }};
      --border-right-hover: {{ block.settings.border_width }}{{ block.settings.border_width_unit | default: 'px' }} {{ block.settings.border_style }} {{ block.settings.border_color_hover }};
    {% elsif border_mode == 'custom' %}
      {% if block.settings.border_top %}--border-top: {{ border_value }};{% endif %}
      {% if block.settings.border_bottom %}--border-bottom: {{ border_value }};{% endif %}
      {% if block.settings.border_left %}--border-left: {{ border_value }};{% endif %}
      {% if block.settings.border_right %}--border-right: {{ border_value }};{% endif %}
      {% if block.settings.border_top %}--border-top-hover: {{ block.settings.border_width }}{{ block.settings.border_width_unit | default: 'px' }} {{ block.settings.border_style }} {{ block.settings.border_color_hover }};{% endif %}
      {% if block.settings.border_bottom %}--border-bottom-hover: {{ block.settings.border_width }}{{ block.settings.border_width_unit | default: 'px' }} {{ block.settings.border_style }} {{ block.settings.border_color_hover }};{% endif %}
      {% if block.settings.border_left %}--border-left-hover: {{ block.settings.border_width }}{{ block.settings.border_width_unit | default: 'px' }} {{ block.settings.border_style }} {{ block.settings.border_color_hover }};{% endif %}
      {% if block.settings.border_right %}--border-right-hover: {{ block.settings.border_width }}{{ block.settings.border_width_unit | default: 'px' }} {{ block.settings.border_style }} {{ block.settings.border_color_hover }};{% endif %}
    {% endif %}
    {%- render 'pl--css-var',
     variableName: 'pl-padding-top',
     baseValue: block.settings.padding_mode,
     overrideTrigger: 'custom',
     overrideValue: block.settings.padding_top,
     overrideUnit: block.settings.padding_unit,
     defaultValue: block.settings.padding_all,
     defaultValueUnit: block.settings.padding_unit
    -%}
    {%- render 'pl--css-var',
     variableName: 'pl-padding-right',
     baseValue: block.settings.padding_mode,
     overrideTrigger: 'custom',
     overrideValue: block.settings.padding_right,
     overrideUnit: block.settings.padding_unit,
     defaultValue: block.settings.padding_all,
     defaultValueUnit: block.settings.padding_unit
    -%}
    {%- render 'pl--css-var',
     variableName: 'pl-padding-bottom',
     baseValue: block.settings.padding_mode,
     overrideTrigger: 'custom',
     overrideValue: block.settings.padding_bottom,
     overrideUnit: block.settings.padding_unit,
     defaultValue: block.settings.padding_all,
     defaultValueUnit: block.settings.padding_unit
    -%}
    {%- render 'pl--css-var',
     variableName: 'pl-padding-left',
     baseValue: block.settings.padding_mode,
     overrideTrigger: 'custom',
     overrideValue: block.settings.padding_left,
     overrideUnit: block.settings.padding_unit,
     defaultValue: block.settings.padding_all,
     defaultValueUnit: block.settings.padding_unit
    -%}
    {%- render 'pl--css-var',
     variableName: 'pl-padding-top-mobile',
     baseValue: block.settings.padding_mode_mobile,
     overrideTrigger: 'custom',
     overrideValue: block.settings.padding_top_mobile,
     overrideUnit: block.settings.padding_unit_mobile,
     defaultValue: block.settings.padding_all_mobile,
     defaultValueUnit: block.settings.padding_unit_mobile
    -%}
    {%- render 'pl--css-var',
     variableName: 'pl-padding-right-mobile',
     baseValue: block.settings.padding_mode_mobile,
     overrideTrigger: 'custom',
     overrideValue: block.settings.padding_right_mobile,
     overrideUnit: block.settings.padding_unit_mobile,
     defaultValue: block.settings.padding_all_mobile,
     defaultValueUnit: block.settings.padding_unit_mobile
    -%}
    {%- render 'pl--css-var',
     variableName: 'pl-padding-bottom-mobile',
     baseValue: block.settings.padding_mode_mobile,
     overrideTrigger: 'custom',
     overrideValue: block.settings.padding_bottom_mobile,
     overrideUnit: block.settings.padding_unit_mobile,
     defaultValue: block.settings.padding_all_mobile,
     defaultValueUnit: block.settings.padding_unit_mobile
    -%}
    {%- render 'pl--css-var',
     variableName: 'pl-padding-left-mobile',
     baseValue: block.settings.padding_mode_mobile,
     overrideTrigger: 'custom',
     overrideValue: block.settings.padding_left_mobile,
     overrideUnit: block.settings.padding_unit_mobile,
     defaultValue: block.settings.padding_all_mobile,
     defaultValueUnit: block.settings.padding_unit_mobile
    -%}
  "
>
  {{ block.settings.label }}
</button>

