{% endcomment %}

{% stylesheet %}
  /* Input Styles */
  .input {
    background-color: var(--bg-color);
    transition: background-color 0.25s ease;

    height: auto;
    width: 100%;

    border-top: var(--border-top, none);
    border-bottom: var(--border-bottom, none);
    border-left: var(--border-left, none);
    border-right: var(--border-right, none);
    border-radius: var(--border-radius, none);

    padding: var(--pl-padding-top) var(--pl-padding-right) var(--pl-padding-bottom)
      var(--pl-padding-left);

    font-family: var(--font-family);
    font-size: var(--font-size);
    color: var(--color);
    text-align: var(--text-alignment);
  }

  .input:focus-visible {
    outline: none;
    border-color: var(--border-color);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--border-color) 50%, transparent);
  }

  .input::selection {
    background-color: color-mix(in srgb, var(--border-color) 50%, transparent);
  }

  .input:hover {
    background-color: var(--bg-color-hover);
  }

  .input::placeholder {
    color: var(--placeholder-color) !important;
    transition: color 0.1s ease;
  }

  .input:hover::placeholder {
    color: var(--placeholder-color-hover) !important;
  }

  /* Textarea Styles */
  .textarea {
    background-color: var(--bg-color);
    transition: background-color 0.25s ease;

    min-height: 6rem;

    border-top: var(--border-top, none);
    border-bottom: var(--border-bottom, none);
    border-left: var(--border-left, none);
    border-right: var(--border-right, none);
    border-radius: var(--border-radius, none);

    font-family: var(--font-family);
    font-size: var(--font-size);
    color: var(--color);
    text-align: var(--text-alignment);

    padding: var(--pl-padding-top) var(--pl-padding-right) var(--pl-padding-bottom)
      var(--pl-padding-left);
  }

  .textarea:focus-visible {
    outline: none;
    border-color: var(--border-color);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--border-color) 50%, transparent);
  }

  .textarea::selection {
    background-color: color-mix(in srgb, var(--border-color) 50%, transparent);
  }

  .textarea:hover {
    background-color: var(--bg-color-hover);
  }

  .textarea::placeholder {
    color: var(--placeholder-color) !important;
    transition: color 0.1s ease;
  }

  .textarea:hover::placeholder {
    color: var(--placeholder-color-hover) !important ;
  }

  .textarea:focus-visible {
    outline-color: var(--border-color);
  }

  @media screen and (max-width: 768px) {
    .input {
      padding: var(--pl-padding-top-mobile) var(--pl-padding-right-mobile)
        var(--pl-padding-bottom-mobile) var(--pl-padding-left-mobile);
    }

    .textarea {
      padding: var(--pl-padding-top-mobile) var(--pl-padding-right-mobile)
        var(--pl-padding-bottom-mobile) var(--pl-padding-left-mobile);
    }
  }
{% endstylesheet %}

{% comment %} Makes the input type dynamic based on the block settings {% endcomment %}
{% if block.settings.input_type == 'email' %}
  {% assign input_type = 'email' %}
{% elsif block.settings.input_type == 'text' %}
  {% assign input_type = 'text' %}
{% elsif block.settings.input_type == 'phone' %}
  {% assign input_type = 'tel' %}
{% endif %}

{% comment %} Create unique field name using placeholder text {% endcomment %}
{% assign field_name = block.settings.placeholder
  | handleize
  | default: block.settings.input_type
%}

{% liquid
  assign bg_color = block.settings.bg_color
  assign bg_color_hover = block.settings.bg_color_hover
  assign custom_font = block.settings.font
  assign font_size = block.settings.font_size | abs | append: 'px'
  assign color = block.settings.color
  assign text_alignment = block.settings.text_alignment
  assign input_style = block.settings.input_style
  assign border_mode = block.settings.border_mode
%}

{% unless custom_font.system? %}
  <style>
    {{ custom_font | font_face: font_display: 'swap' }}
  </style>
{% endunless %}

{% comment %} Only construct border_value if border_mode is not 'none' {% endcomment %}
{% if border_mode != 'none' %}
  {% liquid
    assign border_value = block.settings.border_width | append: block.settings.border_width_unit | append: ' ' | append: block.settings.border_style | append: ' ' | append: block.settings.border_color
  %}
{% endif %}

{% comment %} Renders the input or textarea based on the block settings {% endcomment %}

{% if input_style == 'textarea' %}
  <div
    style="display: flex; flex-direction: column; gap: 8px; font-family: {{ custom_font.family | remove: '"' }};"
  >
    <label for="textarea" class="label">{{ block.settings.label }}</label>
    <textarea
      {{ block.shopify_attributes }}
      class="textarea"
      name="contact[{{ field_name }}]"
      style="
        --bg-color: {{ bg_color }};
        --bg-color-hover: {{ bg_color_hover }};
        --placeholder-color: {{ block.settings.placeholder_color }};
        --placeholder-color-hover: {{ block.settings.placeholder_color_hover }};
        --border-color: {{ block.settings.border_color }};
        --border-radius: {{ block.settings.border_radius | append: 'px' }};
        --font-family: {{ custom_font.family | remove: '"' }};
        --font-size: {{ font_size }};
        --color: {{ color }};
        --text-alignment: {{ text_alignment }};
        {% if border_mode == 'all' %}
          --border-top: {{ border_value }};
          --border-bottom: {{ border_value }};
          --border-left: {{ border_value }};
          --border-right: {{ border_value }};
        {% elsif border_mode == 'custom' %}
          {% if block.settings.border_top %}--border-top: {{ border_value }};{% endif %}
          {% if block.settings.border_bottom %}--border-bottom: {{ border_value }};{% endif %}
          {% if block.settings.border_left %}--border-left: {{ border_value }};{% endif %}
          {% if block.settings.border_right %}--border-right: {{ border_value }};{% endif %}
        {% endif %}
        {%- render 'pl--css-var',
         variableName: 'pl-padding-top',
         baseValue: block.settings.padding_mode,
         overrideTrigger: 'custom',
         overrideValue: block.settings.padding_top,
         overrideUnit: block.settings.padding_unit,
         defaultValue: block.settings.padding_all,
         defaultValueUnit: block.settings.padding_unit
        -%}
        {%- render 'pl--css-var',
         variableName: 'pl-padding-right',
         baseValue: block.settings.padding_mode,
         overrideTrigger: 'custom',
         overrideValue: block.settings.padding_right,
         overrideUnit: block.settings.padding_unit,
         defaultValue: block.settings.padding_all,
         defaultValueUnit: block.settings.padding_unit
        -%}
        {%- render 'pl--css-var',
         variableName: 'pl-padding-bottom',
         baseValue: block.settings.padding_mode,
         overrideTrigger: 'custom',
         overrideValue: block.settings.padding_bottom,
         overrideUnit: block.settings.padding_unit,
         defaultValue: block.settings.padding_all,
         defaultValueUnit: block.settings.padding_unit
        -%}
        {%- render 'pl--css-var',
         variableName: 'pl-padding-left',
         baseValue: block.settings.padding_mode,
         overrideTrigger: 'custom',
         overrideValue: block.settings.padding_left,
         overrideUnit: block.settings.padding_unit,
         defaultValue: block.settings.padding_all,
         defaultValueUnit: block.settings.padding_unit
        -%}
        {%- render 'pl--css-var',
         variableName: 'pl-padding-top-mobile',
         baseValue: block.settings.padding_mode_mobile,
         overrideTrigger: 'custom',
         overrideValue: block.settings.padding_top_mobile,
         overrideUnit: block.settings.padding_unit_mobile,
         defaultValue: block.settings.padding_all_mobile,
         defaultValueUnit: block.settings.padding_unit_mobile
        -%}
        {%- render 'pl--css-var',
         variableName: 'pl-padding-right-mobile',
         baseValue: block.settings.padding_mode_mobile,
         overrideTrigger: 'custom',
         overrideValue: block.settings.padding_right_mobile,
         overrideUnit: block.settings.padding_unit_mobile,
         defaultValue: block.settings.padding_all_mobile,
         defaultValueUnit: block.settings.padding_unit_mobile
        -%}
        {%- render 'pl--css-var',
         variableName: 'pl-padding-bottom-mobile',
         baseValue: block.settings.padding_mode_mobile,
         overrideTrigger: 'custom',
         overrideValue: block.settings.padding_bottom_mobile,
         overrideUnit: block.settings.padding_unit_mobile,
         defaultValue: block.settings.padding_all_mobile,
         defaultValueUnit: block.settings.padding_unit_mobile
        -%}
        {%- render 'pl--css-var',
         variableName: 'pl-padding-left-mobile',
         baseValue: block.settings.padding_mode_mobile,
         overrideTrigger: 'custom',
         overrideValue: block.settings.padding_left_mobile,
         overrideUnit: block.settings.padding_unit_mobile,
         defaultValue: block.settings.padding_all_mobile,
         defaultValueUnit: block.settings.padding_unit_mobile
        -%}
      "
      placeholder="{{ block.settings.placeholder }}"
      {% if block.settings.required %}
        required
      {% endif %}
    ></textarea>
  </div>
{% else %}
  <div style="font-family: {{ custom_font.family | remove: '"' }};">
    {% if block.settings.label != blank %}
      <label for="input" class="label" style="margin-bottom: 0.5rem;">
        {{- block.settings.label -}}
      </label>
    {% endif %}
    <input
      {{ block.shopify_attributes }}
      class="input"
      style="
        --bg-color: {{ bg_color }};
        --bg-color-hover: {{ bg_color_hover }};
        --placeholder-color: {{ block.settings.placeholder_color }};
        --placeholder-color-hover: {{ block.settings.placeholder_color_hover }};
        --border-color: {{ block.settings.border_color }};
        --border-radius: {{ block.settings.border_radius | append: 'px' }};
        --font-family: {{ custom_font.family | remove: '"' }};
        --font-size: {{ font_size }};
        --color: {{ color }};
        --text-alignment: {{ text_alignment }};
        {% if border_mode == 'all' %}
          --border-top: {{ border_value }};
          --border-bottom: {{ border_value }};
          --border-left: {{ border_value }};
          --border-right: {{ border_value }};
        {% elsif border_mode == 'custom' %}
          {% if block.settings.border_top %}--border-top: {{ border_value }};{% endif %}
          {% if block.settings.border_bottom %}--border-bottom: {{ border_value }};{% endif %}
          {% if block.settings.border_left %}--border-left: {{ border_value }};{% endif %}
          {% if block.settings.border_right %}--border-right: {{ border_value }};{% endif %}
        {% endif %}
        {%- render 'pl--css-var',
         variableName: 'pl-padding-top',
         baseValue: block.settings.padding_mode,
         overrideTrigger: 'custom',
         overrideValue: block.settings.padding_top,
         overrideUnit: block.settings.padding_unit,
         defaultValue: block.settings.padding_all,
         defaultValueUnit: block.settings.padding_unit
        -%}
        {%- render 'pl--css-var',
         variableName: 'pl-padding-right',
         baseValue: block.settings.padding_mode,
         overrideTrigger: 'custom',
         overrideValue: block.settings.padding_right,
         overrideUnit: block.settings.padding_unit,
         defaultValue: block.settings.padding_all,
         defaultValueUnit: block.settings.padding_unit
        -%}
        {%- render 'pl--css-var',
         variableName: 'pl-padding-bottom',
         baseValue: block.settings.padding_mode,
         overrideTrigger: 'custom',
         overrideValue: block.settings.padding_bottom,
         overrideUnit: block.settings.padding_unit,
         defaultValue: block.settings.padding_all,
         defaultValueUnit: block.settings.padding_unit
        -%}
        {%- render 'pl--css-var',
         variableName: 'pl-padding-left',
         baseValue: block.settings.padding_mode,
         overrideTrigger: 'custom',
         overrideValue: block.settings.padding_left,
         overrideUnit: block.settings.padding_unit,
         defaultValue: block.settings.padding_all,
         defaultValueUnit: block.settings.padding_unit
        -%}
        {%- render 'pl--css-var',
         variableName: 'pl-padding-top-mobile',
         baseValue: block.settings.padding_mode_mobile,
         overrideTrigger: 'custom',
         overrideValue: block.settings.padding_top_mobile,
         overrideUnit: block.settings.padding_unit_mobile,
         defaultValue: block.settings.padding_all_mobile,
         defaultValueUnit: block.settings.padding_unit_mobile
        -%}
        {%- render 'pl--css-var',
         variableName: 'pl-padding-right-mobile',
         baseValue: block.settings.padding_mode_mobile,
         overrideTrigger: 'custom',
         overrideValue: block.settings.padding_right_mobile,
         overrideUnit: block.settings.padding_unit_mobile,
         defaultValue: block.settings.padding_all_mobile,
         defaultValueUnit: block.settings.padding_unit_mobile
        -%}
        {%- render 'pl--css-var',
         variableName: 'pl-padding-bottom-mobile',
         baseValue: block.settings.padding_mode_mobile,
         overrideTrigger: 'custom',
         overrideValue: block.settings.padding_bottom_mobile,
         overrideUnit: block.settings.padding_unit_mobile,
         defaultValue: block.settings.padding_all_mobile,
         defaultValueUnit: block.settings.padding_unit_mobile
        -%}
        {%- render 'pl--css-var',
         variableName: 'pl-padding-left-mobile',
         baseValue: block.settings.padding_mode_mobile,
         overrideTrigger: 'custom',
         overrideValue: block.settings.padding_left_mobile,
         overrideUnit: block.settings.padding_unit_mobile,
         defaultValue: block.settings.padding_all_mobile,
         defaultValueUnit: block.settings.padding_unit_mobile
        -%}
      "
      type="{{ input_type }}"
      placeholder="{{ block.settings.placeholder }}"
      name="contact[{{ field_name }}]"
      {% if block.settings.required %}
        required
      {% endif %}
    >
  </div>
{% endif %}

{% schema %}
{
  "name": "Input (PL)",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "Customize the section to your liking. Need help? Check our [documentation](https://www.pentlibrary.com/docs)."
    },
    {
      "type": "select",
      "id": "settings_view",
      "label": "Settings for",
      "options": [
        { "value": "all", "label": "All" },
        { "value": "desktop", "label": "Desktop" },
        { "value": "mobile", "label": "Mobile" }
      ],
      "default": "all"
    },
    {
      "type": "header",
      "content": "🌐 Input Settings",
      "visible_if": "{{ block.settings.settings_view == 'all' }}"
    },
    {
      "type": "select",
      "id": "input_type",
      "label": "Input Type",
      "options": [
        { "value": "email", "label": "Email" },
        { "value": "text", "label": "Text" },
        { "value": "phone", "label": "Phone" }
      ],
      "default": "email",
      "visible_if": "{{ block.settings.settings_view == 'all' }}"
    },
    {
      "type": "select",
      "id": "input_style",
      "label": "Input Style",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "textarea", "label": "Textarea" }
      ],
      "default": "normal",
      "visible_if": "{{ block.settings.settings_view == 'all' }}"
    },
    {
      "type": "checkbox",
      "id": "required",
      "label": "Required",
      "default": true,
      "visible_if": "{{ block.settings.settings_view == 'all' }}"
    },
    {
      "type": "header",
      "content": "🌐 Placeholder",
      "visible_if": "{{ block.settings.settings_view == 'all' }}"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Placeholder text",
      "default": "Enter your email",
      "visible_if": "{{ block.settings.settings_view == 'all' }}"
    },
    {
      "type": "select",
      "id": "placeholder_state",
      "label": "Placeholder State",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "hover", "label": "Hover" }
      ],
      "default": "normal",
      "visible_if": "{{ block.settings.settings_view == 'all' }}"
    },
    {
      "type": "color",
      "id": "placeholder_color",
      "label": "Placeholder Color",
      "default": "#999",
      "visible_if": "{{ block.settings.settings_view == 'all' and block.settings.placeholder_state == 'normal' }}"
    },
    {
      "type": "color",
      "id": "placeholder_color_hover",
      "label": "Placeholder Color (Hover)",
      "default": "#999",
      "visible_if": "{{ block.settings.settings_view == 'all' and block.settings.placeholder_state == 'hover' }}"
    },
    {
      "type": "header",
      "content": "🌐 Background",
      "visible_if": "{{ block.settings.settings_view == 'all' }}"
    },
    {
      "type": "select",
      "id": "background_state",
      "label": "Background State",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "hover", "label": "Hover" }
      ],
      "default": "normal",
      "visible_if": "{{ block.settings.settings_view == 'all' }}"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f0f0f0",
      "visible_if": "{{ block.settings.settings_view == 'all' and block.settings.background_state == 'normal' }}"
    },
    {
      "type": "color",
      "id": "bg_color_hover",
      "label": "Background Color (Hover)",
      "default": "#f0f0f0",
      "visible_if": "{{ block.settings.settings_view == 'all' and block.settings.background_state == 'hover' }}"
    },
    {
      "type": "header",
      "content": "🌐 Font",
      "visible_if": "{{ block.settings.settings_view == 'all' }}"
    },
    {
      "type": "font_picker",
      "id": "font",
      "label": "Font",
      "default": "inter_n4",
      "visible_if": "{{ block.settings.settings_view == 'all' }}"
    },
    {
      "type": "number",
      "id": "font_size",
      "label": "Font Size",
      "placeholder": "Enter a value in pixels",
      "default": 16,
      "visible_if": "{{ block.settings.settings_view == 'all' }}"
    },
    {
      "type": "color",
      "id": "color",
      "label": "Color",
      "visible_if": "{{ block.settings.settings_view == 'all' }}"
    },
    {
      "type": "text_alignment",
      "id": "text_alignment",
      "label": "Align",
      "default": "left",
      "visible_if": "{{ block.settings.settings_view == 'all' }}"
    },
    {
      "type": "header",
      "content": "🌐 Border",
      "visible_if": "{{ block.settings.settings_view == 'all' }}"
    },
    {
      "type": "select",
      "id": "border_mode",
      "label": "Border",
      "options": [
        { "value": "all", "label": "All" },
        { "value": "custom", "label": "Custom" },
        { "value": "none", "label": "None" }
      ],
      "visible_if": "{{ block.settings.settings_view == 'all' }}"
    },
    {
      "type": "paragraph",
      "content": "Choose which borders to style",
      "visible_if": "{{ block.settings.border_mode == 'custom' and block.settings.settings_view == 'all' }}"
    },
    {
      "type": "checkbox",
      "id": "border_top",
      "label": "Top border",
      "default": true,
      "visible_if": "{{ block.settings.border_mode == 'custom' and block.settings.settings_view == 'all' }}"
    },
    {
      "type": "checkbox",
      "id": "border_bottom",
      "label": "Bottom border",
      "default": true,
      "visible_if": "{{ block.settings.border_mode == 'custom' and block.settings.settings_view == 'all' }}"
    },
    {
      "type": "checkbox",
      "id": "border_left",
      "label": "Left border",
      "default": true,
      "visible_if": "{{ block.settings.border_mode == 'custom' and block.settings.settings_view == 'all' }}"
    },
    {
      "type": "checkbox",
      "id": "border_right",
      "label": "Right border",
      "default": true,
      "visible_if": "{{ block.settings.border_mode == 'custom' and block.settings.settings_view == 'all' }}"
    },
    {
      "type": "select",
      "id": "border_style",
      "label": "Style",
      "options": [
        { "value": "solid", "label": "─ Solid" },
        { "value": "dashed", "label": "┄ Dashed" },
        { "value": "dotted", "label": "⋯ Dotted" }
      ],
      "default": "solid",
      "visible_if": "{{ block.settings.border_mode != 'none' and block.settings.settings_view == 'all' }}"
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Width",
      "min": 0,
      "max": 10,
      "step": 0.1,
      "default": 1,
      "visible_if": "{{ block.settings.border_mode != 'none' and block.settings.settings_view == 'all' }}"
    },
    {
      "type": "select",
      "id": "border_width_unit",
      "label": "Width Unit",
      "options": [
        { "value": "px", "label": "px" },
        { "value": "rem", "label": "rem" },
        { "value": "em", "label": "em" },
        { "value": "%", "label": "%" },
        { "value": "vw", "label": "vw" },
        { "value": "vh", "label": "vh" },
        { "value": "svh", "label": "svh" },
        { "value": "svw", "label": "svw" }
      ],
      "default": "px",
      "visible_if": "{{ block.settings.border_mode != 'none' and block.settings.use_custom_units == true and block.settings.settings_view == 'all' }}"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Color",
      "default": "#999",
      "visible_if": "{{ block.settings.border_mode != 'none' and block.settings.settings_view == 'all' }}"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border Radius",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 6,
      "visible_if": "{{ block.settings.settings_view == 'all' and block.settings.border_mode != 'none' }}"
    },
    {
      "type": "header",
      "content": "🌐 Label",
      "visible_if": "{{ block.settings.settings_view == 'all' }}"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "visible_if": "{{ block.settings.settings_view == 'all' }}"
    },
    {
      "type": "header",
      "content": "🖥️ Padding",
      "visible_if": "{{ block.settings.settings_view != 'mobile' }}"
    },
    {
      "type": "select",
      "id": "padding_mode",
      "label": "Padding Mode",
      "options": [
        { "value": "all", "label": "All sides" },
        { "value": "custom", "label": "Custom sides" }
      ],
      "default": "all",
      "visible_if": "{{ block.settings.settings_view != 'mobile' }}"
    },
    {
      "type": "number",
      "id": "padding_all",
      "label": "All Sides",
      "placeholder": "Enter a value",
      "default": 8,
      "visible_if": "{{ block.settings.padding_mode == 'all' and block.settings.settings_view != 'mobile' }}"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "Top",
      "placeholder": "Enter a value",
      "visible_if": "{{ block.settings.padding_mode == 'custom' and block.settings.settings_view != 'mobile' }}"
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "Bottom",
      "placeholder": "Enter a value",
      "visible_if": "{{ block.settings.padding_mode == 'custom' and block.settings.settings_view != 'mobile' }}"
    },
    {
      "type": "number",
      "id": "padding_left",
      "label": "Left",
      "placeholder": "Enter a value",
