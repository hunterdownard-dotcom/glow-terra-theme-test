<div class="blog-post-content rte gt-blog-content" data-gt-blog-content>
  <rte-formatter>
    {{ article.content }}
  </rte-formatter>

  <div class="gt-blog-topic-images" aria-hidden="true">
    {% if section.settings.topic_image_1 != blank %}
      <figure class="gt-blog-topic-image" data-gt-blog-topic-image>
        {{
          section.settings.topic_image_1
          | image_url: width: 1400
          | image_tag:
            loading: 'lazy',
            widths: '400, 700, 1000, 1400',
            sizes: '(min-width: 990px) 860px, calc(100vw - 40px)',
            alt: section.settings.topic_image_1.alt
        }}
        {% if section.settings.topic_image_1_caption != blank %}
          <figcaption>{{ section.settings.topic_image_1_caption }}</figcaption>
        {% endif %}
      </figure>
    {% endif %}

    {% if section.settings.topic_image_2 != blank %}
