</div>

<script>
  (function(){
    var script = document.currentScript;
    var content = script ? script.previousElementSibling : null;

    if (!content || !content.matches('[data-gt-blog-content]') || content.dataset.topicImagesReady === 'true') return;
    content.dataset.topicImagesReady = 'true';

    var formatter = content.querySelector('rte-formatter');
    var imageWrap = content.querySelector('.gt-blog-topic-images');
    if (!formatter || !imageWrap) return;

    var images = Array.prototype.slice.call(imageWrap.querySelectorAll('[data-gt-blog-topic-image]'));
    if (!images.length) return;

    var anchors = Array.prototype.slice.call(formatter.querySelectorAll('h2, h3, h4, hr'));

    if (!anchors.length) {
      var children = Array.prototype.slice.call(formatter.children);
      anchors = children.filter(function(node, index){
        if (index < 2 || !node.textContent) return false;

        var text = node.textContent.trim();
        var isShort = text.length > 8 && text.length <= 90;
        var looksLikeTitle = isShort && !/[.!?]$/.test(text);
        var hasStrongStart = !!node.querySelector('strong, b');

        return looksLikeTitle || hasStrongStart;
      });
    }

    if (anchors.length) {
      images.forEach(function(image, index){
        var anchor = anchors[index];
        if (!anchor) return;

        image.removeAttribute('aria-hidden');
        anchor.insertAdjacentElement('beforebegin', image);
      });
      return;
    }

    var paragraphs = Array.prototype.slice.call(formatter.querySelectorAll('p')).filter(function(p){
      return p.textContent.trim().length > 70;
    });

    if (!paragraphs.length) {
      imageWrap.removeAttribute('aria-hidden');
      imageWrap.classList.add('gt-blog-topic-images--fallback');
      return;
    }

    var spacing = Math.max(2, Math.floor(paragraphs.length / (images.length + 1)));

    images.forEach(function(image, index){
      var target = paragraphs[Math.min(paragraphs.length - 1, ((index + 1) * spacing) - 1)];
      if (!target) return;

      image.removeAttribute('aria-hidden');
      target.insertAdjacentElement('afterend', image);
    });
  })();
</script>

{% stylesheet %}
  .blog-post-content {
    max-width: var(--normal-content-width);
    margin: 0 auto;
  }

  .gt-blog-content {
    max-width: 100%;
    padding: clamp(22px, 3.4vw, 38px);
    color: #211a16;
    text-align: left;
  }

  .gt-blog-content rte-formatter {
    display: block;
    max-width: none;
    margin-inline: 0;
  }

  .gt-blog-content :is(p, li) {
    color: #3f352e;
    font-size: clamp(14px, 1.05vw, 15.5px);
    font-weight: 400;
    line-height: 1.68;
  }

  .gt-blog-content p {
    margin: 0 0 0.9em;
  }

  .gt-blog-content p:first-child {
    color: #342820;
    font-size: clamp(15px, 1.2vw, 17px);
    font-weight: 400;
    line-height: 1.66;
  }

  .gt-blog-content :is(h2, h3, h4) {
    margin: 1.55em 0 0.55em;
    color: #211a16;
    line-height: 1.1;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .gt-blog-content h2 {
    position: relative;
    padding-top: 22px;
    border-top: 1px solid rgba(64, 81, 63, 0.18);
    color: #40513f;
    font-family: var(--font-primary--family);
    font-size: clamp(25px, 2.7vw, 36px);
    font-weight: 760;
  }

  .gt-blog-content h2:before {
    content: "";
    position: absolute;
    top: -1px;
    left: 0;
    width: 74px;
    height: 2px;
    border-radius: 999px;
    background: #b08a57;
  }

  .gt-blog-content h3 {
    color: #40513f;
    font-family: var(--font-primary--family);
    font-size: clamp(20px, 2vw, 28px);
    font-weight: 720;
  }

  .gt-blog-content h4 {
    color: #94664f;
    font-size: 18px;
    font-weight: 700;
  }

  .gt-blog-content :is(ul, ol) {
    display: grid;
    gap: 8px;
    margin: 1.05em 0;
    padding: 17px 20px 17px 38px;
    border: 1px solid rgba(64, 81, 63, 0.12);
    border-radius: 10px;
    background: linear-gradient(145deg, #fffaf4, #f6eadc);
  }

  .gt-blog-content li::marker {
    color: #40513f;
    font-weight: 800;
  }

  .gt-blog-content blockquote {
    margin: 1.45em 0;
    padding: clamp(18px, 2.6vw, 26px);
    border-left: 4px solid #40513f;
    border-radius: 0 10px 10px 0;
    background: #f6eadc;
    color: #211a16;
    box-shadow: 0 18px 46px rgba(66, 48, 34, 0.08);
  }

  .gt-blog-content blockquote :is(p, li) {
    color: #342820;
    font-size: clamp(16px, 1.45vw, 19px);
    font-weight: 400;
    line-height: 1.6;
  }

  .gt-blog-content a {
    color: #344b3a;
    font-weight: 650;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .gt-blog-content strong,
  .gt-blog-content b {
    color: #40513f;
    font-weight: 650;
  }

  .gt-blog-content img {
    display: block;
    width: 100%;
    height: auto;
    margin: 1.6em auto;
    border-radius: 10px;
    box-shadow: 0 20px 54px rgba(66, 48, 34, 0.12);
  }

  .gt-blog-content hr {
    width: 100%;
    height: 1px;
    margin: 1.9em 0;
    border: 0;
    background: rgba(64, 81, 63, 0.18);
  }

  .gt-blog-topic-images {
    display: none;
  }

  .gt-blog-topic-images--fallback {
    display: grid;
    gap: 18px;
    margin-top: 24px;
  }

  .gt-blog-topic-image {
    display: block;
    margin: 2em 0 1.4em;
    border: 1px solid rgba(64, 81, 63, 0.13);
    border-radius: 10px;
    padding: 10px;
    background: rgba(255, 250, 244, 0.78);
    box-shadow: 0 22px 58px rgba(66, 48, 34, 0.1);
  }

  .gt-blog-topic-image img {
    margin: 0;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    box-shadow: none;
  }

  .gt-blog-topic-image figcaption {
    margin: 9px 4px 0;
    color: #675c52;
    font-size: 12.5px;
    line-height: 1.45;
    text-align: center;
  }

  @media screen and (max-width: 749px) {
    .gt-blog-content {
      padding: 20px 16px;
    }

    .gt-blog-content :is(p, li) {
      font-size: 14.5px;
      line-height: 1.62;
    }

    .gt-blog-content p:first-child {
      font-size: 15.5px;
    }

    .gt-blog-content h2 {
      font-size: clamp(24px, 7.5vw, 32px);
    }

    .gt-blog-content :is(ul, ol) {
      padding: 16px 16px 16px 32px;
      border-radius: 8px;
    }

    .gt-blog-topic-image {
      margin: 1.6em 0 1.1em;
      border-radius: 8px;
      padding: 8px;
    }

    .gt-blog-topic-image img {
      border-radius: 7px;
    }
  }
{% endstylesheet %}

