<script
  src="{{ 'blog-posts-list.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

<blog-posts-list section-id="{{ section.id }}">
  <div class="section-background color-{{ section.settings.color_scheme }}"></div>
  <div
    class="
      section
      color-{{ section.settings.color_scheme }}
      blog-posts
      gt-blog-index
      spacing-style
      size-style
    "
    data-testid="blog-posts"
    style="{% render 'spacing-style', settings: section.settings %}"
  >
    <div class="gt-blog-index__intro">
      {% content_for 'blocks' %}
    </div>

    <div
      ref="grid"
      class="blog-posts-container"
    >
      {% liquid
        assign items_on_page = blog.articles.size
      %}
      {% for article in blog.articles %}
        {% liquid
          assign col_span = 2
          assign scale = 0.6
          assign is_horizontal = false

          case items_on_page
            when 1
              assign col_span = 6
              assign scale = 1
              assign is_horizontal = true
            when 2
              assign col_span = 3
              assign scale = 0.8
            when 3
              if forloop.index == 1
                assign col_span = 6
                assign scale = 1
                assign is_horizontal = true
              else
                assign col_span = 3
                assign scale = 0.8
              endif
            when 4
              assign col_span = 3
              assign scale = 0.8
            when 5
              if forloop.index == 1
                assign col_span = 6
                assign scale = 1
                assign is_horizontal = true
              else
                assign col_span = 3
                assign scale = 0.8
              endif
            else
              if forloop.index == 1
                assign col_span = 6
                assign scale = 1
                assign is_horizontal = true
              elsif forloop.index <= 3
                assign col_span = 3
                assign scale = 0.8
              else
                assign col_span = 2
                assign scale = 0.6
              endif
          endcase
        %}
        {% style %}
          [data-blog-index="{{ section.id }}-{{ forloop.index }}"] {
            --col-span: {{ col_span }};
            --blog-post-card-scale: {{ scale }};
          }

          @media screen and (max-width: 749px) {
            [data-blog-index="{{ section.id }}-{{ forloop.index }}"] {
              --col-span: 6;
              --blog-post-card-scale: 0.72;
            }
          }
        {% endstyle %}
        <div
          class="blog-post-item{% if is_horizontal %} blog-post-item--horizontal{% endif %}"
          data-testid="blog-post-item"
          data-blog-index="{{ section.id }}-{{ forloop.index }}"
        >
          {% content_for 'block', id: 'static-blog-post-card', type: '_blog-post-card', article: article %}
        </div>
      {% endfor %}
    </div>
  </div>
</blog-posts-list>

{% stylesheet %}
  .blog-posts {
    --page-content-width: var(--narrow-page-width);
    --page-width: calc(var(--page-content-width) + (var(--page-margin) * 2));
    --columns-gap: 24px;
    --rows-gap: 24px;
  }

  .gt-blog-index {
    background:
      radial-gradient(circle at 12% 0%, rgba(176, 138, 87, 0.12), transparent 32%),
      linear-gradient(180deg, #fffaf4 0%, #f8efe4 52%, #fffdf8 100%);
    color: #211a16;
  }

  .gt-blog-index__intro {
    width: min(1080px, calc(100% - 40px));
    margin-inline: auto;
  }

  .gt-blog-index__intro h1 {
    color: #211a16;
    font-size: clamp(38px, 5vw, 64px);
    line-height: 1.05;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .blog-posts-container {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1rem;
    width: min(1080px, calc(100% - 40px));
    margin-inline: auto;
    column-gap: var(--columns-gap);
    row-gap: var(--rows-gap);
  }

  .blog-post-item {
    grid-column: span var(--col-span);
    overflow: hidden;
    border: 1px solid rgba(64, 81, 63, 0.13);
    border-radius: 10px;
    padding: 0 1rem 1rem;
    background: rgba(255, 253, 248, 0.9);
    box-shadow: 0 20px 54px rgba(66, 48, 34, 0.1);
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }

  .blog-post-item:has(.blog-post-card__image-container) {
    border: 1px solid rgba(64, 81, 63, 0.13);
    padding: 0;
  }

  .blog-post-item:hover {
    transform: translateY(-3px);
    border-color: rgba(64, 81, 63, 0.24);
    box-shadow: 0 26px 72px rgba(66, 48, 34, 0.14);
  }

  .gt-blog-index .blog-post-card {
    height: 100%;
    background: linear-gradient(145deg, #fffdf8, #f7ecdf);
  }

  .gt-blog-index .blog-post-card__image {
    border-radius: 10px 10px 0 0;
    filter: saturate(0.95) contrast(0.98);
  }

  .gt-blog-index .blog-post-card__content {
    padding: 18px 18px 20px;
  }

  .gt-blog-index .blog-post-card__content a {
    color: #211a16;
    text-decoration: none;
  }

  .gt-blog-index .blog-post-card__content h2,
  .gt-blog-index .blog-post-card__content h3,
  .gt-blog-index .blog-post-card__content h4 {
    color: #211a16;
    letter-spacing: 0;
    line-height: 1.12;
    text-wrap: balance;
  }

  .gt-blog-index .blog-post-card__content-text {
    color: #675c52;
    line-height: 1.62;
  }

  .gt-blog-index .blog-post-card__content-text a {
    display: inline-flex;
    width: fit-content;
    margin-top: 12px;
    border-bottom: 1px solid rgba(64, 81, 63, 0.36);
    color: #344b3a;
    font-weight: 900;
  }

  .blog-post-item--horizontal:has(.blog-post-card__image-container) .blog-post-card {
    border: 1px solid rgba(64, 81, 63, 0.12);
    border-radius: 10px;
    background: linear-gradient(135deg, #fffdf8, #f4e7d7);
  }

  @media screen and (max-width: 749px) {
    .gt-blog-index__intro,
    .blog-posts-container {
      width: min(100% - 28px, 1080px);
    }

    .blog-posts-container {
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .blog-post-item {
      grid-column: 1 / -1;
      border-radius: 8px;
    }

    .gt-blog-index .blog-post-card__image {
      border-radius: 8px 8px 0 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.blog_posts",
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    },
    {
      "type": "text"
    },
    {
      "type": "icon"
    },
    {
      "type": "image"
    },
    {
      "type": "button"
    },
    {
      "type": "video"
    },
    {
      "type": "group"
    },
    {
      "type": "spacer"
    },
    {
      "type": "_divider"
    }
  ],
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}
