{% render 'gt-premium-styles' %}
{% render 'gt-bottom-nav' %}

<section class="gt-store gt-collection">
  <div class="gt-collection-hero">
    {% if section.settings.banner_image != blank %}
      {{ section.settings.banner_image | image_url: width: 1800 | image_tag: class: 'gt-collection-hero__bg', loading: 'eager', alt: section.settings.banner_image.alt }}
    {% elsif collection.image != blank %}
      {{ collection.image | image_url: width: 1800 | image_tag: class: 'gt-collection-hero__bg', loading: 'eager', alt: collection.title }}
    {% endif %}
    <div class="gt-wrap gt-collection-hero__inner">
      <p class="gt-eyebrow">{{ section.settings.eyebrow }}</p>
      <h1 class="gt-title">{{ collection.title }}</h1>
      {% if collection.description != blank %}
        <div class="gt-copy">{{ collection.description }}</div>
      {% else %}
        <p class="gt-copy">{{ section.settings.fallback_text }}</p>
      {% endif %}
    </div>
  </div>

  <div class="gt-wrap gt-collection-toolbar">
    <span>{{ collection.products_count }} products</span>
    <a href="{{ routes.all_products_collection_url }}">All products</a>
  </div>

  {% paginate collection.products by section.settings.products_per_page %}
    <div class="gt-wrap gt-collection-grid">
      {% for product in collection.products %}
        {% render 'gt-product-card', product: product, show_quick_add: section.settings.enable_quick_add %}
      {% else %}
        <p class="gt-copy">No products found in this collection yet.</p>
      {% endfor %}
    </div>

    {% if paginate.pages > 1 %}
      <nav class="gt-wrap gt-pagination" aria-label="Pagination">
        {% if paginate.previous %}<a class="gt-btn gt-btn--outline" href="{{ paginate.previous.url }}">Previous</a>{% endif %}
        <span>Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
        {% if paginate.next %}<a class="gt-btn gt-btn--outline" href="{{ paginate.next.url }}">Next</a>{% endif %}
      </nav>
    {% endif %}
  {% endpaginate %}
</section>

<style>
  .gt-collection-hero{position:relative;isolation:isolate;min-height:360px;display:grid;align-items:end;background:#efe4d7;overflow:hidden}
  .gt-collection-hero__bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:-2}
  .gt-collection-hero:after{content:"";position:absolute;inset:0;background:linear-gradient(90deg,rgba(251,247,240,.94),rgba(251,247,240,.72),rgba(251,247,240,.25));z-index:-1}
  .gt-collection-hero__inner{padding:88px 0 56px}.gt-collection-hero h1{font-size:clamp(44px,6vw,72px)}.gt-collection-hero .gt-copy{max-width:620px}
  .gt-collection-toolbar{display:flex;justify-content:space-between;gap:18px;align-items:center;padding:28px 0;color:var(--gt-muted);font-weight:700}.gt-collection-toolbar a{color:var(--gt-moss);border-bottom:1px solid currentColor}
  .gt-collection-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;padding-bottom:72px}
  .gt-pagination{display:flex;align-items:center;justify-content:center;gap:16px;padding-bottom:72px;color:var(--gt-muted)}
  @media(max-width:990px){.gt-collection-grid{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:680px){.gt-collection-hero{min-height:300px}.gt-collection-hero__inner{padding:68px 0 40px}.gt-collection-grid{grid-template-columns:1fr;gap:16px}.gt-collection-toolbar{padding:20px 0}.gt-pagination{display:grid;text-align:center}}
</style>

{% schema %}
{
  "name": "Glow Terra Collection",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop Glow Terra" },
    { "type": "textarea", "id": "fallback_text", "label": "Fallback description", "default": "Premium natural skincare bars made with botanical oils, clean ingredients, and everyday routines in mind." },
    { "type": "image_picker", "id": "banner_image", "label": "Collection banner image" },
    { "type": "checkbox", "id": "enable_quick_add", "label": "Enable quick add", "default": true },
    { "type": "range", "id": "products_per_page", "label": "Products per page", "min": 8, "max": 48, "step": 4, "default": 24 }
  ],
  "presets": [{ "name": "Glow Terra Collection" }]
}
{% endschema %}
