{% comment %}
  Section: contact 5
  Version: 0.5.0
  Dependencies:
    Blocks: pl--form-block, pl--grid, pl--group, pl--heading, pl--input, pl--submit-button, pl--text, pl--video
    Snippets: pl--video-shopify, pl--video-vimeo, pl--video-youtube
    Assets: pl--video-placeholder-landscape.png
  ===================================================
  IMPORTANT - PLEASE READ BEFORE MODIFYING THIS FILE
  ===================================================
  This is a Pent Library section template.
  - Please report bugs to support@pentlibrary.com. Include the section ID and version in the email.
  - Modifying this file may break functionality and changes might be automatically overwritten.
  - For best practices, visit our docs: https://www.pentlibrary.com/docs
{% endcomment %}

{% stylesheet %}
  .pl--section-wrapper {
    letter-spacing: 0;
  }

  .pl--contact-5__bg {
    background-color: var(--bg-color, transparent);
    grid-column: 1 / -1;
  }

  .pl--contact-5__page-width {
    max-width: var(--max-width, none);
  }

  /* Mobile-first: Base styles are for mobile */
  .pl--contact-5__inline-padding {
    padding-left: var(--pl-padding-left);
    padding-right: var(--pl-padding-right);
  }

  .pl--contact-5__container {
    max-width: var(--max-width, none);
  }

  .pl--contact-5__custom-padding {
    padding-top: var(--pl-padding-top);
    padding-bottom: var(--pl-padding-bottom);
  }

  .pl--contact-5__grid {
    display: grid;
    grid-auto-columns: 1fr;
    grid-column-gap: var(--gap, 0);
    grid-row-gap: var(--gap, 0);
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto;
    align-items: center;
  }

  /* Tablet and down: Override desktop styles */
  @media screen and (max-width: 768px) {
    .pl--contact-5__inline-padding {
      padding-left: var(--pl-padding-left-mobile);
      padding-right: var(--pl-padding-right-mobile);
    }

    .pl--contact-5__custom-padding {
      padding-top: var(--pl-padding-top-mobile);
      padding-bottom: var(--pl-padding-bottom-mobile);
    }

    .pl--contact-5__grid {
      grid-column-gap: var(--gap-mobile, 0);
      grid-row-gap: var(--gap-mobile, 0);
      grid-template-columns: 1fr;
    }
  }

  /* Legacy support for existing preset classes */
  .--pl--contact-5-padding-left-group {
    padding-left: 5vw !important;
  }

  @media screen and (max-width: 768px) {
    .--pl--contact-5-padding-left-group {
      padding-left: 5% !important;
      padding-right: 5% !important;
    }
  }
{% endstylesheet %}

<div
  class="--pl--section-wrapper pl--contact-5__bg"
  style="
    --bg-color: {{ section.settings.bg_color }};
    --max-width: {{ section.settings.max_width }}{{ section.settings.max_width_unit }};
    --gap: {{ section.settings.gap }}{{ section.settings.gap_unit }};
    --gap-mobile: {{ section.settings.gap_mob }}{{ section.settings.gap_unit_mobile }};
    {%- render 'pl--css-var',
         variableName: 'pl-padding-top',
         baseValue: section.settings.padding_mode,
         overrideTrigger: 'custom',
         overrideValue: section.settings.padding_top,
         overrideUnit: section.settings.padding_unit,
         defaultValue: section.settings.padding_all,
         defaultValueUnit: section.settings.padding_unit
        -%}
        {%- render 'pl--css-var',
         variableName: 'pl-padding-right',
         baseValue: section.settings.padding_mode,
         overrideTrigger: 'custom',
         overrideValue: section.settings.padding_right,
         overrideUnit: section.settings.padding_unit,
         defaultValue: section.settings.padding_all,
         defaultValueUnit: section.settings.padding_unit
        -%}
        {%- render 'pl--css-var',
         variableName: 'pl-padding-bottom',
         baseValue: section.settings.padding_mode,
         overrideTrigger: 'custom',
         overrideValue: section.settings.padding_bottom,
         overrideUnit: section.settings.padding_unit,
         defaultValue: section.settings.padding_all,
         defaultValueUnit: section.settings.padding_unit
        -%}
        {%- render 'pl--css-var',
         variableName: 'pl-padding-left',
         baseValue: section.settings.padding_mode,
         overrideTrigger: 'custom',
         overrideValue: section.settings.padding_left,
         overrideUnit: section.settings.padding_unit,
         defaultValue: section.settings.padding_all,
         defaultValueUnit: section.settings.padding_unit
        -%}
        {%- render 'pl--css-var',
         variableName: 'pl-padding-top-mobile',
         baseValue: section.settings.padding_mode_mobile,
         overrideTrigger: 'custom',
         overrideValue: section.settings.padding_top_mobile,
         overrideUnit: section.settings.padding_unit_mobile,
         defaultValue: section.settings.padding_all_mobile,
         defaultValueUnit: section.settings.padding_unit_mobile
        -%}
        {%- render 'pl--css-var',
         variableName: 'pl-padding-right-mobile',
         baseValue: section.settings.padding_mode_mobile,
         overrideTrigger: 'custom',
         overrideValue: section.settings.padding_right_mobile,
         overrideUnit: section.settings.padding_unit_mobile,
         defaultValue: section.settings.padding_all_mobile,
         defaultValueUnit: section.settings.padding_unit_mobile
        -%}
        {%- render 'pl--css-var',
         variableName: 'pl-padding-bottom-mobile',
         baseValue: section.settings.padding_mode_mobile,
         overrideTrigger: 'custom',
         overrideValue: section.settings.padding_bottom_mobile,
         overrideUnit: section.settings.padding_unit_mobile,
         defaultValue: section.settings.padding_all_mobile,
         defaultValueUnit: section.settings.padding_unit_mobile
        -%}
        {%- render 'pl--css-var',
         variableName: 'pl-padding-left-mobile',
         baseValue: section.settings.padding_mode_mobile,
         overrideTrigger: 'custom',
         overrideValue: section.settings.padding_left_mobile,
         overrideUnit: section.settings.padding_unit_mobile,
         defaultValue: section.settings.padding_all_mobile,
         defaultValueUnit: section.settings.padding_unit_mobile
        -%}
  "
>
  <div class="--pl--page-width-global">
    <div class="pl--contact-5__inline-padding">
      <div class="pl--contact-5__container">
        <div class="pl--contact-5__custom-padding">
          <div class="pl--contact-5__grid">
            {% content_for 'blocks' %}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

