{% comment %}
  Section: Hero 8
  Version: 1.0.0
  
  ===================================================
  IMPORTANT - PLEASE READ BEFORE MODIFYING THIS FILE
  ===================================================
  
  This is a Pent Library section template. 
  - Please report bugs to support@pentlibrary.com. Include the section ID and version in the email.
  - Modifying the file may break the section, edit at own risk
  - For best practices, visit our docs: https://www.pentlibrary.com/docs

{% endcomment %}

{% style %}
  /* Base styles - customize as needed */
  .pl--hero-8-bg-{{ section.id }} {
    position: relative;
    {% if section.settings.height == "fill" %}
      height: 100vh;
      display: flex;
      align-content: {{ section.settings.align_content }};
      flex-wrap: wrap;
    {% endif %}
  }

  .pl--hero-8-container-{{ section.id }} {
    {% if section.settings.max_width > 0 %}max-width: {{ section.settings.max_width }}px;{% endif %}
  }

  /* Padding styles */
  .pl--hero-8-inline-padding-{{ section.id }} {
    {% if section.settings.padding_left != 0 and section.settings.padding_left != blank %}
      padding-left: {{ section.settings.padding_left }}px;
    {% endif %}
    {% if section.settings.padding_right != 0 and section.settings.padding_right != blank %}
      padding-right: {{ section.settings.padding_right }}px;
    {% endif %}
  }

  .pl--hero-8-custom-padding-{{ section.id }} {
    {% if section.settings.padding_top != 0 and section.settings.padding_top != blank %}
      padding-top: {{ section.settings.padding_top }}px;
    {% endif %}
    {% if section.settings.padding_bottom != 0 and section.settings.padding_bottom != blank %}
      padding-bottom: {{ section.settings.padding_bottom }}px;
    {% endif %}

    display: flex;
    justify-content: {{ section.settings.justify_content }};
  }

  /* Layout styles - customize based on your design */
  .pl--hero-8-layout-{{ section.id }} {
    display: grid;
    gap: {{ section.settings.gap }}px;
    grid-auto-columns: 1fr;
    grid-template-columns: minmax(0px, 1fr);
    grid-template-rows: auto;
    align-items: center;
    position: relative;
    z-index: 1;

    max-width: {{ section.settings.content_width | abs | at_least: 350 | append: 'px' }};
  }

  /* Mobile styles */
  @media screen and (max-width: 768px) {
    .pl--hero-8-bg-{{ section.id }} {
      {% if section.settings.height_mob == "fill" %}
        height: 100vh;
        display: flex;
        align-content: {{ section.settings.align_content_mob }};
        flex-wrap: wrap;
      {% endif %}
    }
    .pl--hero-8-inline-padding-{{ section.id }} {
      {% if section.settings.padding_left_mob != 0 and section.settings.padding_left_mob != blank %}
        padding-left: {{ section.settings.padding_left_mob }}px;
      {% endif %}
      {% if section.settings.padding_right_mob != 0 and section.settings.padding_right_mob != blank %}
        padding-right: {{ section.settings.padding_right_mob }}px;
      {% endif %}
    }

    .pl--hero-8-custom-padding-{{ section.id }} {
      {% if section.settings.padding_top_mob != 0 and section.settings.padding_top_mob != blank %}
        padding-top: {{ section.settings.padding_top_mob }}px;
      {% endif %}
      {% if section.settings.padding_bottom_mob != 0 and section.settings.padding_bottom_mob != blank %}
        padding-bottom: {{ section.settings.padding_bottom_mob }}px;
      {% endif %}

      justify-content: {{ section.settings.justify_content_mob }};
    }

    .pl--hero-8-layout-{{ section.id }} {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<div class="--pl--section-wrapper pl--hero-8-bg-{{ section.id }} {{ section.settings.custom_class }}">
  <div class="--pl--page-width-global" style="width: 100%;">
    <div class="--pl--padding-global pl--hero-8-inline-padding-{{ section.id }}">
      <div class="pl--hero-8-container-{{ section.id }}">
        <div class="--pl--padding-section-medium pl--hero-8-custom-padding-{{ section.id }}">
          <div class="pl--hero-8-layout-{{ section.id }}">
            {% content_for 'blocks' %}
          </div>
        </div>
      </div>
    </div>
  </div>
  {% render 'pl--background-video', 
    video: section.settings.video,
    video_mob: section.settings.video_mob,
    autoplay: section.settings.autoplay,
    autoplay_mob: section.settings.autoplay_mob,
    loop: section.settings.loop,
    loop_mob: section.settings.loop_mob,
    mute: true,
    controls: section.settings.controls,
    controls_mob: section.settings.controls_mob,
    overlay_opacity: section.settings.overlay,
    overlay_opacity_mob: section.settings.overlay_mob,
    alt: section.settings.alt,
    section: section
  %}
</div>

