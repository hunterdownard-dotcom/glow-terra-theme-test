{% render 'gt-premium-styles' %}
{% render 'gt-bottom-nav' %}

{% liquid
  assign featured_collection = section.settings.featured_collection
  assign collection_url = routes.all_products_collection_url
  if featured_collection != blank
    assign collection_url = featured_collection.url
  endif

  assign bundle_product = section.settings.bundle_product
  assign bundle_url = collection_url
  if bundle_product != blank
    assign bundle_url = bundle_product.url
  endif
%}

<section class="gt-store gt-home" aria-label="Glow Terra homepage">
  <div class="gt-home-hero">
    {% if section.settings.hero_image != blank %}
      {{ section.settings.hero_image | image_url: width: 2200 | image_tag: class: 'gt-home-hero__bg', loading: 'eager', alt: section.settings.hero_image.alt }}
    {% else %}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'gt-home-hero__bg' }}
    {% endif %}
    <div class="gt-home-hero__inner gt-wrap">
      <div class="gt-home-hero__copy">
        <p class="gt-eyebrow">{{ section.settings.hero_eyebrow }}</p>
        <h1 class="gt-title">{{ section.settings.hero_heading }}</h1>
        <p>{{ section.settings.hero_text }}</p>
        <div class="gt-home-hero__actions">
          <a class="gt-btn gt-btn--dark" href="{{ collection_url }}">Shop Collection</a>
          <a class="gt-btn gt-btn--light" href="{{ bundle_url }}">Bundle &amp; Save</a>
        </div>
        <div class="gt-home-hero__pills">
          <span>Fragrance-free focus</span>
          <span>Plant oil base</span>
          <span>Small batch crafted</span>
        </div>
      </div>
      <aside class="gt-home-hero__feature" aria-label="Glow Terra product preview">
        {% if section.settings.hero_side_image != blank %}
          {{ section.settings.hero_side_image | image_url: width: 900 | image_tag: loading: 'eager', alt: section.settings.hero_side_image.alt }}
        {% elsif bundle_product.featured_image != blank %}
          {{ bundle_product.featured_image | image_url: width: 900 | image_tag: loading: 'eager', alt: bundle_product.title }}
        {% else %}
          {{ 'product-1' | placeholder_svg_tag }}
        {% endif %}
        <div>
          <strong>Multi-oil formulas</strong>
          <span>Crafted with botanical oils, butters, and skin-first ingredients.</span>
        </div>
      </aside>
    </div>
  </div>

  <div class="gt-home-trust">
    <span>100% Natural Ingredients</span>
    <span>Secure Checkout</span>
    <span>Fast U.S. Shipping</span>
    <span>Small Batch Crafted</span>
  </div>

  <section class="gt-section gt-wrap">
    <div class="gt-heading">
      <div>
        <p class="gt-eyebrow">Shop the routine</p>
        <h2 class="gt-title">Purposeful bars for skin, scalp, and glow.</h2>
      </div>
      <a class="gt-heading__link" href="{{ collection_url }}">View all products</a>
    </div>
    <div class="gt-home-products">
      {% assign rendered_products = 0 %}
      {% for block in section.blocks %}
        {% if block.type == 'featured_product' and block.settings.product != blank %}
          {% render 'gt-product-card', product: block.settings.product, show_quick_add: true %}
          {% assign rendered_products = rendered_products | plus: 1 %}
        {% endif %}
      {% endfor %}
      {% if rendered_products == 0 %}
        {% liquid
          assign fallback_collection = featured_collection
          if fallback_collection == blank
            assign fallback_collection = collections.all
          endif
        %}
        {% for product in fallback_collection.products limit: 4 %}
          {% render 'gt-product-card', product: product, show_quick_add: true %}
        {% endfor %}
      {% endif %}
    </div>
  </section>

  <section class="gt-section gt-wrap gt-home-why">
    <div>
      <p class="gt-eyebrow">Why Glow Terra</p>
      <h2 class="gt-title">Skincare-first soap, built around ingredient density.</h2>
      <p class="gt-copy">Each bar is designed around botanical oils and butters, so the cleansing experience feels intentional, gentle, and elevated.</p>
    </div>
    <div class="gt-home-why__grid">
      <article class="gt-card"><span>01</span><h3>Multi-oil formulations</h3><p>Coconut, olive, castor, shea, jojoba, and targeted botanicals work together.</p></article>
      <article class="gt-card"><span>02</span><h3>Ingredient density</h3><p>The formula keeps the focus on oils, butters, and plant-based actives.</p></article>
      <article class="gt-card"><span>03</span><h3>Fragrance-free focus</h3><p>No artificial fragrance. Just a more comfortable bar for function-first routines.</p></article>
      <article class="gt-card"><span>04</span><h3>Skincare-first philosophy</h3><p>Refined bars created to support daily routines with a clean, trustworthy feel.</p></article>
    </div>
  </section>

  <section class="gt-section gt-wrap gt-home-center">
    <p class="gt-eyebrow">Customer feedback</p>
    <h2 class="gt-title">Quiet results customers come back to.</h2>
    <div class="gt-home-reviews">
      {% assign rendered_reviews = 0 %}
      {% for block in section.blocks %}
        {% if block.type == 'review' %}
          {% assign rendered_reviews = rendered_reviews | plus: 1 %}
          <article class="gt-card gt-home-review" {{ block.shopify_attributes }}>
            {% if block.settings.avatar != blank %}
              {{ block.settings.avatar | image_url: width: 160 | image_tag: loading: 'lazy', alt: block.settings.name }}
            {% else %}
              <div class="gt-home-review__avatar" aria-hidden="true"><span>{{ block.settings.name | slice: 0 }}</span></div>
            {% endif %}
            <div>
              <span class="gt-rating" aria-label="Customer rating">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
              <p>"{{ block.settings.quote }}"</p>
              <strong>{{ block.settings.name }}</strong>
            </div>
          </article>
        {% endif %}
      {% endfor %}
      {% if rendered_reviews == 0 %}
        <article class="gt-card gt-home-review">
          <div class="gt-home-review__avatar" aria-hidden="true"><span>M</span></div>
          <div>
            <span class="gt-rating" aria-label="Customer rating">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
            <p>"The Turmeric Bar feels clean and gentle on my skin."</p>
            <strong>Maya R.</strong>
          </div>
        </article>
        <article class="gt-card gt-home-review">
          <div class="gt-home-review__avatar" aria-hidden="true"><span>J</span></div>
          <div>
            <span class="gt-rating" aria-label="Customer rating">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
            <p>"The Batana bar has become part of my weekly routine."</p>
            <strong>Jordan L.</strong>
          </div>
        </article>
        <article class="gt-card gt-home-review">
          <div class="gt-home-review__avatar" aria-hidden="true"><span>A</span></div>
          <div>
            <span class="gt-rating" aria-label="Customer rating">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
            <p>"Simple ingredients, nice lather, and my skin does not feel tight after."</p>
            <strong>Alina P.</strong>
          </div>
        </article>
      {% endif %}
    </div>
  </section>

  <section class="gt-section gt-wrap">
    <div class="gt-heading">
      <div>
        <p class="gt-eyebrow">Ingredient library</p>
        <h2 class="gt-title">Botanicals chosen for a clean, comfortable routine.</h2>
      </div>
    </div>
    <div class="gt-home-ingredients">
      {% for block in section.blocks %}
        {% if block.type == 'ingredient' %}
          <article {{ block.shopify_attributes }}>
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 700 | image_tag: loading: 'lazy', alt: block.settings.title }}
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag }}
            {% endif %}
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </section>

  <section class="gt-home-sale gt-wrap">
    {% if section.settings.banner_image != blank %}
      {{ section.settings.banner_image | image_url: width: 1800 | image_tag: class: 'gt-home-sale__bg', loading: 'lazy', alt: section.settings.banner_image.alt }}
    {% endif %}
    <div>
      <p class="gt-eyebrow">Limited bundle value</p>
      <h2 class="gt-title">Real Ingredients. Real Results.</h2>
      <p>Build a complete routine with the 3-Bar Bundle for <strong>$19.99</strong>.</p>
    </div>
    <a class="gt-btn gt-btn--dark" href="{{ bundle_url }}">Shop 3-Bar Bundle</a>
  </section>

  <section class="gt-section gt-wrap gt-home-center">
    <p class="gt-eyebrow">Glow Terra Routine Guide</p>
    <h2 class="gt-title">Simple ways to use each bar with confidence.</h2>
    <div class="gt-home-social">
      {% for block in section.blocks %}
        {% if block.type == 'social_image' %}
          <article class="gt-routine-card" {{ block.shopify_attributes }}>
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 700 | image_tag: loading: 'lazy', alt: block.settings.alt }}
            {% else %}
              {{ 'lifestyle-2' | placeholder_svg_tag }}
            {% endif %}
            <div>
              <h3>{{ block.settings.title }}</h3>
              <p>{{ block.settings.text }}</p>
            </div>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </section>

  <section class="gt-home-newsletter">
    <div class="gt-wrap gt-home-newsletter__inner">
      <div>
        <p class="gt-eyebrow">Glow notes</p>
        <h2 class="gt-title">Join The Glow Terra Community</h2>
        <p class="gt-copy">Get early access to restocks, bundles, and ingredient education.</p>
      </div>
      <div>
        {% form 'customer', class: 'gt-home-newsletter__form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <label class="visually-hidden" for="gt-newsletter-email">Email address</label>
          <input class="gt-field" id="gt-newsletter-email" type="email" name="contact[email]" placeholder="Email address" required>
          <button class="gt-btn gt-btn--dark" type="submit">Sign Up</button>
        {% endform %}
        <div class="gt-home-newsletter__trust">
          <span>No spam</span>
          <span>Restock alerts</span>
          <span>Bundle updates</span>
        </div>
      </div>
    </div>
  </section>
</section>

<style>
  .gt-home-hero{position:relative;min-height:760px;display:grid;align-items:center;background:#1f1a16;color:#fff;overflow:hidden}
  .gt-home-hero__bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;filter:saturate(.86) contrast(.96)}
  .gt-home-hero:after{content:"";position:absolute;inset:0;background:linear-gradient(90deg,rgba(30,22,17,.84),rgba(45,35,28,.58) 46%,rgba(246,230,211,.16)),linear-gradient(0deg,rgba(20,15,12,.45),rgba(20,15,12,.08))}
  .gt-home-hero__inner{position:relative;z-index:1;display:grid;grid-template-columns:minmax(0,1fr) 430px;gap:56px;align-items:center;padding:96px 0 74px}
  .gt-home-hero h1{font-size:clamp(46px,6vw,78px);max-width:850px;color:#fff}
  .gt-home-hero__copy>p:not(.gt-eyebrow){max-width:560px;margin:22px 0 0;font-size:20px;line-height:1.55;color:rgba(255,255,255,.86)}
  .gt-home-hero__actions,.gt-home-hero__pills{display:flex;gap:12px;flex-wrap:wrap;margin-top:34px}
  .gt-home-hero__pills{margin-top:28px;gap:10px}
  .gt-home-hero__pills span{border:1px solid rgba(255,255,255,.26);border-radius:999px;padding:8px 12px;font-size:13px;color:rgba(255,255,255,.86)}
  .gt-home-hero__feature{position:relative;border:1px solid rgba(255,255,255,.28);background:rgba(255,250,244,.12);backdrop-filter:blur(14px);padding:14px;border-radius:8px;box-shadow:0 30px 80px rgba(0,0,0,.24)}
  .gt-home-hero__feature img,.gt-home-hero__feature svg{width:100%;aspect-ratio:4/5;object-fit:cover;border-radius:6px}
  .gt-home-hero__feature div{position:absolute;left:-28px;bottom:34px;width:250px;background:#fffaf4;color:var(--gt-ink);border:1px solid rgba(36,29,24,.08);border-radius:8px;padding:16px;box-shadow:0 24px 60px rgba(36,29,24,.18)}
  .gt-home-hero__feature strong{display:block;margin-bottom:5px}.gt-home-hero__feature span{font-size:13px;color:var(--gt-muted);line-height:1.5}
  .gt-home-trust{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--gt-line);border-block:1px solid var(--gt-line)}
  .gt-home-trust span{display:flex;align-items:center;justify-content:center;background:var(--gt-card);padding:18px 12px;font-size:14px;font-weight:700;text-align:center}
  .gt-home-products{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}
  .gt-home-why{display:grid;grid-template-columns:.9fr 1.35fr;gap:44px;align-items:start}
  .gt-home-why__grid,.gt-home-reviews{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}
  .gt-home-why article,.gt-home-reviews article{padding:24px}.gt-home-why span{color:var(--gt-clay);font-weight:800}
  .gt-home-center{text-align:center}.gt-home-center .gt-title{margin-inline:auto}
  .gt-home-reviews{grid-template-columns:repeat(3,1fr);margin-top:34px;text-align:left}
  .gt-home-review{position:relative;display:grid;grid-template-columns:66px 1fr;gap:18px;align-items:start;background:linear-gradient(145deg,#fffdf8 0%,#f5eadc 100%);border-color:rgba(70,81,59,.12);box-shadow:0 26px 72px rgba(63,76,54,.13)}
  .gt-home-review:before{content:"";position:absolute;inset:0;border-radius:8px;background:linear-gradient(135deg,rgba(176,138,87,.12),rgba(64,81,63,.05));pointer-events:none}
  .gt-home-review>*{position:relative}
  .gt-home-review img,.gt-home-review__avatar{width:66px;height:66px;border-radius:50%;object-fit:cover;background:linear-gradient(135deg,#d9c2a4,#f4eadc);color:#40513f;display:grid;place-items:center;font-weight:900;border:2px solid rgba(255,255,255,.9);box-shadow:0 12px 28px rgba(66,48,34,.14)}
  .gt-home-review__avatar{position:relative;overflow:hidden}
  .gt-home-review__avatar:before{content:"";position:absolute;top:13px;width:20px;height:20px;border-radius:50%;background:rgba(64,81,63,.35)}
  .gt-home-review__avatar:after{content:"";position:absolute;bottom:10px;width:38px;height:24px;border-radius:999px 999px 12px 12px;background:rgba(64,81,63,.24)}
  .gt-home-review__avatar span{position:relative;z-index:1;margin-top:8px;color:#fff;text-shadow:0 1px 5px rgba(33,26,22,.28)}
  .gt-home-review p{margin:8px 0 12px;line-height:1.62;color:var(--gt-ink);font-size:15px}
  .gt-home-review strong{color:#40513f}
  .gt-home-ingredients{display:grid;grid-template-columns:repeat(5,1fr);gap:14px}
  .gt-home-ingredients article{background:var(--gt-card);border:1px solid rgba(36,29,24,.08);border-radius:8px;overflow:hidden}
  .gt-home-ingredients img,.gt-home-ingredients svg{width:100%;aspect-ratio:1;object-fit:cover}.gt-home-ingredients h3,.gt-home-ingredients p{padding-inline:16px}.gt-home-ingredients p{padding-bottom:18px;color:var(--gt-muted);line-height:1.55;font-size:14px}
  .gt-home-sale{position:relative;overflow:hidden;margin-top:18px;padding:44px;border-radius:8px;display:flex;align-items:center;justify-content:space-between;gap:24px;background:#3f3a2c;color:#fff;box-shadow:0 24px 70px rgba(36,29,24,.16)}
  .gt-home-sale:after{content:"";position:absolute;inset:0;background:linear-gradient(135deg,rgba(49,39,32,.88),rgba(89,98,70,.82));z-index:0}.gt-home-sale>*{position:relative;z-index:1}.gt-home-sale__bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}
  .gt-home-sale h2{font-size:clamp(32px,4vw,52px);color:#fff}.gt-home-sale p:not(.gt-eyebrow){font-size:18px;color:rgba(255,255,255,.86)}.gt-home-sale .gt-eyebrow{color:#ead8c2}
  .gt-home-social{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-top:34px;text-align:left}.gt-routine-card{background:var(--gt-card);border:1px solid rgba(36,29,24,.08);border-radius:8px;overflow:hidden;box-shadow:0 18px 42px rgba(66,48,34,.1)}.gt-routine-card img,.gt-routine-card svg{width:100%;height:260px;object-fit:cover}.gt-routine-card div{padding:18px}.gt-routine-card h3{margin:0 0 8px;font-size:18px}.gt-routine-card p{margin:0;color:var(--gt-muted);line-height:1.55;font-size:14px}
  .gt-home-newsletter{margin:10px 0 0;padding:52px 0;background:linear-gradient(135deg,#344b3a,#5d6b48);color:#fff}
  .gt-home-newsletter__inner{display:grid;grid-template-columns:.95fr 1.05fr;gap:44px;align-items:center}
  .gt-home-newsletter .gt-eyebrow{color:#e7d3b8}.gt-home-newsletter .gt-copy{max-width:520px;color:rgba(255,255,255,.78)}
  .gt-home-newsletter h2{font-size:clamp(32px,4vw,50px);color:#fff}
  .gt-home-newsletter__form{display:grid;grid-template-columns:1fr auto;gap:10px;margin:0}.gt-home-newsletter__form .gt-field{border-color:rgba(255,255,255,.24);background:rgba(255,253,248,.96)}
  .gt-home-newsletter__form .gt-btn{background:#fffdf8;color:#211a16!important;box-shadow:none}
  .gt-home-newsletter__trust{display:flex;gap:8px;flex-wrap:wrap;margin-top:14px}.gt-home-newsletter__trust span{border:1px solid rgba(255,255,255,.22);border-radius:999px;padding:7px 10px;font-size:12px;font-weight:800;color:rgba(255,255,255,.82)}
  @media(max-width:990px){.gt-home-hero__inner{grid-template-columns:1fr}.gt-home-products{grid-template-columns:repeat(2,1fr)}.gt-home-trust{grid-template-columns:repeat(2,1fr)}.gt-home-why{grid-template-columns:1fr}.gt-home-ingredients{grid-template-columns:repeat(3,1fr)}.gt-home-social{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:680px){.gt-home-hero{min-height:auto}.gt-home-hero__inner{padding:70px 0 48px}.gt-home-hero h1{font-size:42px}.gt-home-hero__actions{display:grid}.gt-home-hero__feature div{left:16px;right:16px;bottom:16px;width:auto}.gt-home-trust,.gt-home-products,.gt-home-why__grid,.gt-home-reviews,.gt-home-ingredients{grid-template-columns:1fr}.gt-home-review{grid-template-columns:52px 1fr}.gt-home-review img,.gt-home-review__avatar{width:52px;height:52px}.gt-home-review__avatar:before{top:10px;width:16px;height:16px}.gt-home-review__avatar:after{bottom:8px;width:30px;height:19px}.gt-home-sale{display:block;padding:32px 22px}.gt-home-sale .gt-btn{margin-top:18px}.gt-home-social{grid-template-columns:1fr;gap:14px}.gt-routine-card img,.gt-routine-card svg{height:220px}.gt-home-newsletter{padding:38px 0}.gt-home-newsletter__inner{grid-template-columns:1fr;gap:22px}.gt-home-newsletter__form{grid-template-columns:1fr}}
</style>

{% schema %}
{
  "name": "Glow Terra Homepage",
  "settings": [
    { "type": "text", "id": "hero_eyebrow", "label": "Hero eyebrow", "default": "Small batch botanical skincare" },
    { "type": "text", "id": "hero_heading", "label": "Hero heading", "default": "Nature-Driven Skincare That Delivers Real Results" },
    { "type": "textarea", "id": "hero_text", "label": "Hero text", "default": "Luxury handcrafted soap bars powered by multi-oil botanical formulations." },
    { "type": "image_picker", "id": "hero_image", "label": "Hero background image" },
    { "type": "image_picker", "id": "hero_side_image", "label": "Hero side image" },
    { "type": "collection", "id": "featured_collection", "label": "Shop collection" },
    { "type": "product", "id": "bundle_product", "label": "Glow Collection Bundle product" },
    { "type": "image_picker", "id": "banner_image", "label": "Bundle banner image" }
  ],
  "blocks": [
    { "type": "featured_product", "name": "Featured product", "settings": [{ "type": "product", "id": "product", "label": "Product" }] },
    { "type": "review", "name": "Review", "settings": [
      { "type": "image_picker", "id": "avatar", "label": "Avatar image" },
      { "type": "text", "id": "name", "label": "Customer name", "default": "Maya R." },
      { "type": "textarea", "id": "quote", "label": "Review", "default": "The Turmeric Bar feels clean and gentle on my skin." }
    ] },
    { "type": "ingredient", "name": "Ingredient", "settings": [
      { "type": "text", "id": "title", "label": "Title", "default": "Turmeric" },
      { "type": "textarea", "id": "text", "label": "Text", "default": "A classic botanical for a clarified, fresh-feeling finish." },
      { "type": "image_picker", "id": "image", "label": "Image" }
    ] },
    { "type": "social_image", "name": "Routine guide item", "settings": [
      { "type": "image_picker", "id": "image", "label": "Image" },
      { "type": "text", "id": "title", "label": "Title", "default": "Cleanse gently" },
      { "type": "textarea", "id": "text", "label": "Text", "default": "Use your selected bar with warm water, then let it dry between uses." },
      { "type": "text", "id": "alt", "label": "Alt text", "default": "Glow Terra skincare routine" }
    ] }
  ],
  "presets": [
    {
      "name": "Glow Terra Homepage",
      "blocks": [
        { "type": "featured_product", "settings": { "product": "turmeric-clarifying-bar" } },
        { "type": "featured_product", "settings": { "product": "carrot-glow-bar" } },
        { "type": "featured_product", "settings": { "product": "batana-scalp-renewal-bar" } },
        { "type": "featured_product", "settings": { "product": "glow-collection-bundle" } },
        { "type": "review", "settings": { "name": "Maya R.", "quote": "The Turmeric Bar feels clean and gentle on my skin." } },
        { "type": "review", "settings": { "name": "Jordan L.", "quote": "The Batana bar has become part of my weekly routine." } },
        { "type": "review", "settings": { "name": "Alina P.", "quote": "Simple ingredients, nice lather, and my skin does not feel tight after." } },
        { "type": "ingredient", "settings": { "title": "Turmeric", "text": "A classic botanical for a clarified, fresh-feeling finish." } },
        { "type": "ingredient", "settings": { "title": "Batana Oil", "text": "A rich oil used in scalp and hair routines for a weekly reset." } },
        { "type": "ingredient", "settings": { "title": "Carrot Extract", "text": "A glow-supporting botanical that pairs with gentle plant oils." } },
        { "type": "ingredient", "settings": { "title": "Shea Butter", "text": "A creamy butter that gives each bar a cushioned feel." } },
        { "type": "ingredient", "settings": { "title": "Jojoba Oil", "text": "A lightweight botanical oil selected for a balanced finish." } },
        { "type": "social_image", "settings": { "title": "Cleanse gently", "text": "Use your selected bar with warm water, then let it dry between uses." } },
