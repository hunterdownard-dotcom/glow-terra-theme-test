<style>
  .gt-store{--gt-ink:#241d18;--gt-muted:#70655b;--gt-soft:#fbf7f0;--gt-card:#fffaf4;--gt-line:#e8ded3;--gt-moss:#4d5a41;--gt-clay:#9a684d;--gt-gold:#a87545;background:var(--gt-soft);color:var(--gt-ink)}
  .gt-store *{box-sizing:border-box}
  .gt-store a{color:inherit;text-decoration:none}
  .gt-wrap{width:min(1180px,calc(100% - 40px));margin-inline:auto}
  .gt-eyebrow{margin:0 0 12px;font-size:12px;line-height:1.2;letter-spacing:.12em;text-transform:uppercase;color:var(--gt-clay);font-weight:700}
  .gt-title{margin:0;font-family:var(--font-h1--family);font-weight:600;letter-spacing:0;line-height:1}
  .gt-copy{color:var(--gt-muted);line-height:1.65}
  .gt-btn,.gt-mini-btn{display:inline-flex;align-items:center;justify-content:center;border-radius:999px;border:1px solid transparent;min-height:48px;padding:0 22px;font-weight:700;font-size:14px;line-height:1;cursor:pointer;transition:transform .2s ease,box-shadow .2s ease,background .2s ease}
  .gt-btn:hover,.gt-mini-btn:hover{transform:translateY(-2px)}
  .gt-btn--dark{background:var(--gt-ink);color:#fff;box-shadow:0 18px 40px rgba(36,29,24,.16)}
  .gt-btn--light{background:#fffaf4;color:var(--gt-ink);border-color:rgba(36,29,24,.14)}
  .gt-btn--outline{background:transparent;color:var(--gt-ink);border-color:rgba(36,29,24,.22)}
  .gt-card{background:var(--gt-card);border:1px solid rgba(36,29,24,.08);border-radius:8px;box-shadow:0 18px 50px rgba(66,48,34,.08)}
  .gt-section{padding:88px 0}
  .gt-heading{display:flex;align-items:end;justify-content:space-between;gap:28px;margin-bottom:34px}
  .gt-heading .gt-title{font-size:clamp(34px,4vw,54px);max-width:720px}
  .gt-heading__link{font-weight:700;color:var(--gt-moss);border-bottom:1px solid currentColor}
  .gt-rating{color:var(--gt-gold);font-size:12px}
  .gt-rating small{color:var(--gt-muted);font-weight:700}
  .gt-price{display:flex;gap:8px;align-items:baseline;flex-wrap:wrap;font-weight:800}
  .gt-price s{color:var(--gt-muted);font-weight:500}
  .gt-mini-btn{min-height:38px;padding:0 14px;background:var(--gt-moss);color:#fff;border:0;font-size:12px;white-space:nowrap}
  .gt-product-card{overflow:hidden;transition:transform .22s ease,box-shadow .22s ease}
  .gt-product-card:hover{transform:translateY(-5px);box-shadow:0 26px 70px rgba(66,48,34,.14)}
  .gt-product-card__image{position:relative;display:block;background:#efe4d7;overflow:hidden}
  .gt-product-card__image img,.gt-product-card__image svg{width:100%;aspect-ratio:4/5;object-fit:cover;transition:transform .4s ease}
  .gt-product-card:hover .gt-product-card__image img{transform:scale(1.04)}
  .gt-badge{position:absolute;z-index:1;top:12px;left:12px;background:#fffaf4;color:var(--gt-clay);border-radius:999px;padding:7px 11px;font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.08em}
  .gt-product-card__body{padding:18px}
  .gt-product-card h3{margin:10px 0 6px;font-size:18px;letter-spacing:0}
  .gt-product-card p{margin:0;color:var(--gt-muted);line-height:1.55}
  .gt-product-card__bottom{display:flex;justify-content:space-between;align-items:center;gap:12px;margin-top:16px}
  .gt-product-card form{margin:0}
  .gt-field{width:100%;min-height:50px;border:1px solid var(--gt-line);border-radius:8px;background:#fff;color:var(--gt-ink);padding:0 15px;font:inherit}
  textarea.gt-field{min-height:150px;padding-top:14px;resize:vertical}
  .gt-accordion{border-top:1px solid var(--gt-line)}
  .gt-accordion details{border-bottom:1px solid var(--gt-line);padding:18px 0}
  .gt-accordion summary{cursor:pointer;font-weight:800}
  .gt-accordion p{margin:10px 0 0;color:var(--gt-muted);line-height:1.6}
  @media(max-width:990px){.gt-section{padding:68px 0}.gt-heading{display:block}.gt-heading__link{display:inline-block;margin-top:16px}.gt-product-card__image img,.gt-product-card__image svg{aspect-ratio:1/1}}
  @media(max-width:680px){.gt-wrap{width:calc(100% - 28px)}.gt-section{padding:56px 0}.gt-heading .gt-title{font-size:34px}.gt-btn{width:100%}}
</style>
