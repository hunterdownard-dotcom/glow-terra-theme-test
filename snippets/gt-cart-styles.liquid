<style>
  :root{
    --gt-cart-ink:#211a16;
    --gt-cart-muted:#675c52;
    --gt-cart-soft:#fbf8f1;
    --gt-cart-card:#fffdf8;
    --gt-cart-line:#e4d4c3;
    --gt-cart-green:#344b3a;
    --gt-cart-green-2:#4f6447;
    --gt-cart-gold:#b18a55;
  }

    #header-component .header-actions__action:has(.header-actions__cart-icon),
  #header-component .action__cart{
    position:relative!important;
    overflow:hidden!important;
    background:linear-gradient(145deg,rgba(255,250,244,.28),rgba(52,75,58,.18))!important;
    background-color:rgba(255,250,244,.24)!important;
    border:1px solid rgba(255,250,244,.42)!important;
    border-color:rgba(255,250,244,.42)!important;
    box-shadow:0 10px 26px rgba(33,26,22,.16),inset 0 1px 0 rgba(255,255,255,.34)!important;
    outline:0!important;
    backdrop-filter:blur(12px);
    -webkit-backdrop-filter:blur(12px);
    color:#fffaf4!important;
  }

  #header-component .header-actions__cart-icon,
  #header-component .header-actions__cart-icon .svg-wrapper{
    position:relative!important;
    z-index:1!important;
    background:transparent!important;
    background-color:transparent!important;
    border:0!important;
    box-shadow:none!important;
    outline:0!important;
    color:#fffaf4!important;
  }

  #header-component .header-actions__action:has(.header-actions__cart-icon)::before,
  #header-component .action__cart::before{
    content:""!important;
    position:absolute!important;
    inset:0!important;
    z-index:0!important;
    pointer-events:none!important;
    background:radial-gradient(circle at 72% 20%,rgba(255,250,244,.35),transparent 32%)!important;
    border:0!important;
    box-shadow:none!important;
  }

  #header-component .header-actions__action:has(.header-actions__cart-icon)::after,
  #header-component .action__cart::after{
    content:""!important;
    position:absolute!important;
    right:7px!important;
    top:7px!important;
    width:7px!important;
    height:11px!important;
    z-index:2!important;
    pointer-events:none!important;
    background:#c9d6b8!important;
    background-color:#c9d6b8!important;
    border:0!important;
    border-radius:100% 0 100% 0!important;
    box-shadow:0 1px 4px rgba(33,26,22,.18)!important;
    transform:rotate(34deg)!important;
  }

  #header-component .header-actions__cart-icon::before,
  #header-component .header-actions__cart-icon::after,
  #header-component .header-actions__cart-icon .svg-wrapper::before,
  #header-component .header-actions__cart-icon .svg-wrapper::after{
    content:none!important;
    background:transparent!important;
    border:0!important;
    box-shadow:none!important;
  }

  #header-component .header-actions__cart-icon svg,
  #header-component .action__cart svg{
    color:#fffaf4!important;
    stroke:currentColor!important;
  }
